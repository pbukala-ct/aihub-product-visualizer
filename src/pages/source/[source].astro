---
import Layout from "@/layouts/Layout.astro";
import { ProductGrid } from "@/components/ProductGrid";
import { AttributeSchemaView } from "@/components/AttributeSchemaView";
import { FeedRunBadge } from "@/components/FeedRunBadge";
import { CatalogDeltaTimeline } from "@/components/CatalogDeltaTimeline";
import {
  getSourceBySlug,
  getLatestFullFeedRun,
  getDeltaRunsSince,
  computeDeltaSummary,
} from "@/lib/services/feed-runs";
import type { AnnotatedDeltaRun } from "@/lib/services/feed-runs";

const { source: slug } = Astro.params;

const source = slug ? await getSourceBySlug(slug) : null;

if (!source) {
  return new Response(null, { status: 404 });
}

const feedRun = await getLatestFullFeedRun(source.id);

const deltaRuns: AnnotatedDeltaRun[] = feedRun
  ? (await getDeltaRunsSince(source.id, feedRun.received_at)).map((delta) => ({
      id: delta.id,
      received_at: delta.received_at,
      type: delta.type,
      product_count: delta.product_count,
      source_id: delta.source_id,
      created_at: delta.created_at,
      summary: computeDeltaSummary(feedRun.products, delta.products),
    }))
  : [];
---

<Layout title={`${source.display_name} · AI Hub Feed Visualiser`}>
  <div class="min-h-screen bg-gray-50">
    <header class="bg-white border-b border-gray-200 px-4 sm:px-6">
      <div class="mx-auto max-w-7xl">
        <!-- Top row: back link + global nav -->
        <div class="flex items-center justify-between gap-4 py-3 border-b border-gray-100">
          <a href="/" class="flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-900 transition-colors">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Catalogues
          </a>
          <nav class="flex items-center gap-4 text-xs text-gray-400">
            <a href="/history" class="hover:text-gray-600 transition-colors">All Feed History</a>
            <a href="/diff" class="hover:text-gray-600 transition-colors">Compare Any Feeds</a>
          </nav>
        </div>
        <!-- Source name + sub-nav tabs -->
        <div class="flex items-center justify-between gap-4 pt-3">
          <div class="flex items-center gap-3">
            <h1 class="text-xl font-semibold text-gray-900">{source.display_name}</h1>
            {feedRun && <FeedRunBadge type={feedRun.type} client:load />}
            <span class="text-xs text-gray-400 font-normal">Full Catalogue</span>
          </div>
          <nav class="flex items-center gap-1 text-sm -mb-px">
            <a
              href={`/source/${source.slug}`}
              class="px-3 py-2 font-medium text-indigo-600 border-b-2 border-indigo-500"
            >
              Products
            </a>
            <a
              href={`/history?source=${source.slug}`}
              class="px-3 py-2 text-gray-500 hover:text-gray-900 border-b-2 border-transparent hover:border-gray-300 transition-colors"
            >
              Feed History
            </a>
            <a
              href={`/diff?source=${source.slug}`}
              class="px-3 py-2 text-gray-500 hover:text-gray-900 border-b-2 border-transparent hover:border-gray-300 transition-colors"
            >
              Compare Feeds
            </a>
          </nav>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-7xl px-4 py-6 sm:px-6">
      {
        feedRun ? (
          <>
            <div class="mb-4 flex items-center justify-between gap-4">
              <p class="text-sm text-gray-500">
                Full feed received{" "}
                {new Date(feedRun.received_at).toLocaleString("en-GB", {
                  dateStyle: "long",
                  timeStyle: "short",
                  timeZone: "UTC",
                })}{" "}
                UTC · {feedRun.product_count.toLocaleString()} products
              </p>
              {feedRun.products.length > 0 && <AttributeSchemaView products={feedRun.products} client:load />}
            </div>

            {feedRun.products.length > 0 ? (
              <ProductGrid products={feedRun.products} client:load />
            ) : (
              <div class="flex flex-col items-center justify-center py-20 text-center">
                <p class="text-gray-500">No products in this feed run.</p>
              </div>
            )}

            <CatalogDeltaTimeline deltaRuns={deltaRuns} fullRunId={feedRun.id} client:load />
          </>
        ) : (
          <div class="flex flex-col items-center justify-center py-32 text-center">
            <svg class="h-16 w-16 text-gray-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M12 5l7 7-7 7" />
            </svg>
            <h2 class="text-lg font-medium text-gray-700">No full feed received yet</h2>
            <p class="mt-2 text-sm text-gray-500 max-w-sm">
              The catalogue will appear here once a full feed is received. Point your AI Hub webhook at{" "}
              <code class="rounded bg-gray-100 px-1.5 py-0.5 font-mono text-xs">
                POST /api/feed/ingest/{source.slug}
              </code>{" "}
              and ensure the feed is sent as a full export.
            </p>
          </div>
        )
      }
    </main>
  </div>
</Layout>
