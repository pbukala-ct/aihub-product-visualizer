---
import Layout from "@/layouts/Layout.astro";
import SignUpForm from "@/components/auth/SignUpForm";

const error = Astro.url.searchParams.get("error");
---

<Layout title="Sign up">
  <div
    class="min-h-screen flex items-center justify-center bg-gradient-to-br from-indigo-900 via-purple-900 to-blue-900 p-4"
  >
    <div class="w-full max-w-sm backdrop-blur-xl bg-white/10 rounded-2xl border border-white/10 p-8 text-white">
      <h1
        class="text-2xl font-bold mb-6 text-center bg-gradient-to-r from-blue-200 to-purple-200 text-transparent bg-clip-text"
      >
        Sign up
      </h1>
      <SignUpForm serverError={error} client:load />
      <p class="mt-4 text-center text-sm text-blue-100/60">
        Already have an account? <a href="/auth/signin" class="text-purple-300 hover:underline">Sign in</a>
      </p>
    </div>
  </div>
</Layout>
