---
import Layout from "@/layouts/Layout.astro";

const isAutoConfirmed = import.meta.env.DEV;

const content = isAutoConfirmed
  ? {
      emoji: "✅",
      heading: "Registration successful",
      description: "Your account has been created. You can now sign in.",
      linkText: "Go to sign in",
    }
  : {
      emoji: "📧",
      heading: "Check your email",
      description: "We've sent a confirmation link to your email address. Click it to activate your account.",
      linkText: "Back to sign in",
    };
---

<Layout title={content.heading}>
  <div
    class="min-h-screen flex items-center justify-center bg-gradient-to-br from-indigo-900 via-purple-900 to-blue-900 p-4"
  >
    <div
      class="w-full max-w-sm backdrop-blur-xl bg-white/10 rounded-2xl border border-white/10 p-8 text-white text-center"
    >
      <div class="text-5xl mb-4">{content.emoji}</div>
      <h1 class="text-2xl font-bold mb-3 bg-gradient-to-r from-blue-200 to-purple-200 text-transparent bg-clip-text">
        {content.heading}
      </h1>
      <p class="text-blue-100/80 mb-6">{content.description}</p>
      <a href="/auth/signin" class="text-purple-300 hover:underline text-sm">
        {content.linkText}
      </a>
    </div>
  </div>
</Layout>
