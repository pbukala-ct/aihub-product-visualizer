---
import Layout from "@/layouts/Layout.astro";

const { user } = Astro.locals;
---

<Layout title="Dashboard">
  <div
    class="min-h-screen flex items-center justify-center bg-gradient-to-br from-indigo-900 via-purple-900 to-blue-900 p-4"
  >
    <div class="backdrop-blur-xl bg-white/10 rounded-2xl border border-white/10 p-8 text-white text-center">
      <h1 class="text-3xl font-bold mb-4 bg-gradient-to-r from-blue-200 to-purple-200 text-transparent bg-clip-text">
        Dashboard
      </h1>
      <p class="text-blue-100/80">
        Welcome, <span class="font-semibold text-white">{user?.email}</span>
      </p>
      <p class="text-blue-100/50 text-sm mt-2">This page is only for authenticated users.</p>
      <form method="POST" action="/api/auth/signout" class="mt-6">
        <button
          type="submit"
          class="rounded-lg bg-white/10 hover:bg-white/20 border border-white/20 px-4 py-2 text-sm transition-colors"
        >
          Sign out
        </button>
      </form>
    </div>
  </div>
</Layout>
