---
import Layout from "@/layouts/Layout.astro";
import AppNav from "@/components/AppNav.astro";
import { FeedRunList } from "@/components/FeedRunList";
import { getAllFeedRuns, getSourceBySlug } from "@/lib/services/feed-runs";

const sourceSlug = Astro.url.searchParams.get("source") ?? undefined;
const source = sourceSlug ? await getSourceBySlug(sourceSlug) : null;
const runs = await getAllFeedRuns(source?.id);
---

<Layout title={source ? `${source.display_name} · Feed History` : "Feed History"}>
  <div class="min-h-screen bg-gray-50">
    <AppNav
      activePage="history"
      source={source ?? undefined}
      activeSourceTab={source ? "history" : undefined}
      backTo={source ? { href: "/", label: "Catalogues" } : undefined}
    />

    <main class="mx-auto max-w-3xl px-4 py-6 sm:px-6">
      <FeedRunList runs={runs} sourceSlug={sourceSlug} client:load />
    </main>
  </div>
</Layout>
